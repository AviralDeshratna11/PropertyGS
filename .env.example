# ═══════════════════════════════════════════════════════════════════════════════
# PropOS Complete Environment Configuration
# Phase 1 (Market/Negotiation) + Phase 2 (AR/Voice/CV) + Phase 3 (XR)
# ═══════════════════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your API keys (NEVER commit .env to version control)
# 3. Leave features blank/false if you don't have API keys yet
# 4. The system gracefully falls back to mock data when APIs aren't available
#
# DEPLOYMENT CHECKLIST:
# ✅ Phase 1 (Market + Negotiation): No external APIs required (local Redis)
# ⚠️  Phase 2 (Voice + CV + GSplat): Requires external APIs
# ❌ Phase 3 (XR/AR): Not yet implemented
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# APPLICATION CORE
# ───────────────────────────────────────────────────────────────────────────────
APP_NAME=PropOS
DEBUG=false
LOG_LEVEL=INFO

# ───────────────────────────────────────────────────────────────────────────────
# DATABASE & CACHE
# ───────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./propos.db
REDIS_URL=redis://localhost:6379/0

# ───────────────────────────────────────────────────────────────────────────────
# CORS (Frontend Access)
# ───────────────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","https://app.propos.io"]

# ═════════════════════════════════════════════════════════════════════════════════════
# PHASE 1: MARKET SEARCH & NEGOTIATION ENGINE
# ═════════════════════════════════════════════════════════════════════════════════════

# ──── Lifestyle Search APIs (Optional — Phase 1 enhancement) ────────────────────────
# These APIs provide contextual property data (sunlight, commute, noise, walkability)
# If not set, Phase 1 still works but lacks lifestyle context

# Shadowmap — Sunlight & irradiance simulation
# Sign up: https://shadowmap.org/
SHADOWMAP_API_KEY=your_shadowmap_key_here
SHADOWMAP_BASE_URL=https://api.shadowmap.org/v1

# INRIX — Commute times & traffic patterns
# Sign up: https://developer.inrix.com/
INRIX_APP_ID=your_inrix_app_id
INRIX_APP_KEY=your_inrix_app_key
INRIX_BASE_URL=https://api.iq.inrix.com/v1

# HowLoud — Acoustic soundscore
# Sign up: https://howloud.com/
HOWLOUD_API_KEY=your_howloud_key_here
HOWLOUD_BASE_URL=https://api.howloud.com/v1

# WalkScore — Walkability & transit scores
# Sign up: https://www.walkscore.com/professional/api.php
WALKSCORE_API_KEY=your_walkscore_key_here
WALKSCORE_BASE_URL=https://api.walkscore.com

# ──── LLM for Agent Orchestration ────────────────────────────────────────────────────
# Choose provider: "anthropic" (recommended) or "openai"
# Both Phase 1 market agents and Phase 2 voice assistant use this
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# Anthropic (Claude) — Recommended for Phase 1 agent logic
# Get API key: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI (GPT) — Alternative for Phase 1; required for Phase 2 voice if using OpenAI
# Get API key: https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_key_here

# ──── Blockchain / Smart Contract Settlement ────────────────────────────────────────
# ETH RPC endpoint (Sepolia testnet for development, mainnet for production)
ETH_RPC_URL=https://sepolia.infura.io/v3/your_infura_key
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
DEPLOYER_PRIVATE_KEY=

# ──── Zero-Knowledge Proofs (Funds Verification) ──────────────────────────────────
# Noir prover for ZKP proof generation
NOIR_PROVER_URL=http://zkp-prover:8080
NOIR_PROVER_API_KEY=

# ──── External Real Estate Data ────────────────────────────────────────────────────
# Dubai Land Department REST API (for title verification)
DLD_API_KEY=your_dld_api_key
DLD_BASE_URL=https://api.dubailand.gov.ae/v1

# ──── Currency & FX Conversion ─────────────────────────────────────────────────────
FX_API_KEY=your_fxapi_key
DEFAULT_CURRENCY=USD
SUPPORTED_CURRENCIES=["USD","AED","EUR","GBP"]

# ──── Multi-Agent Reinforcement Learning (Negotiation Engine) ──────────────────────
MARL_CHECKPOINT_DIR=/data/marl_checkpoints
MARL_TRAINING_EPISODES=50000
MARL_LEARNING_RATE=0.0003
MARL_GAMMA=0.99
MARL_GAE_LAMBDA=0.95
MARL_CLIP_EPSILON=0.2
MARL_ENTROPY_COEFF=0.01
MARL_VALUE_LOSS_COEFF=0.5

# ═════════════════════════════════════════════════════════════════════════════════════
# PHASE 2: ADVANCED FEATURES (Perception, Inspection, Voice, IoT)
# ═════════════════════════════════════════════════════════════════════════════════════

# ──── VOICE ASSISTANT (STT/TTS/LLM) – CRITICAL FOR PHASE 2 ──────────────────────────
# This is a key differentiator — enables conversational property tours

VOICE_ENABLE=true

# Speech-to-Text (STT) — Convert user voice to text
# Provider: "openai" (uses Whisper API) or "local" (requires local model)
VOICE_STT_PROVIDER=openai

# Text-to-Speech (TTS) — Convert AI responses back to voice
# Provider: "openai" (recommended) or "elevenlabs"
VOICE_TTS_PROVIDER=openai

# ElevenLabs API key (alternative TTS with better voice diversity)
# Sign up: https://elevenlabs.io/
ELEVENLABS_API_KEY=your_elevenlabs_key

# LLM context size for conversation history
VOICE_LLM_CONTEXT_SIZE=2048

# ──── COMPUTER VISION (Defect Detection) – CRITICAL FOR PHASE 2 ────────────────────
# Enables automated property inspection: structural analysis, crack detection, moisture

INSPECTION_ENABLE=true

# YOLOv12 model weights (attention-centric architecture for defect detection)
# Download from: https://github.com/ultralytics/yolov12 (once released)
# Or use pre-trained weights: https://huggingface.co/ultralytics/yolov12
YOLOV12_MODEL_PATH=/models/yolov12.pt

# RT-DETR model weights (Real-Time Detection Transformer)
# Download from: https://github.com/PaddlePaddle/PaddleDetection
RTDETR_MODEL_PATH=/models/rtdetr.pt

# CracksGPT model weights (Vision-language for crack analysis)
# Custom model — set path if available
CRACKSGPT_MODEL_PATH=/models/cracksgpt.pt

# Confidence threshold for defect detection (0.0-1.0)
INSPECTION_CONFIDENCE_THRESHOLD=0.35

# NMS (Non-Maximum Suppression) threshold for overlapping detections
INSPECTION_NMS_THRESHOLD=0.45

# Device for inference: "cpu" (slow but works everywhere) or "cuda" (fast, GPU required)
INSPECTION_DEVICE=cpu

# ──── 3D GAUSSIAN SPLATTING (GSplat Viewer) – PHASE 2 PERCEPTION ────────────────────
# Enables photorealistic 3D property walkthroughs in WebGL

GSPLAT_ENABLE=true

# Path to pre-trained GSplat model or .splat scene files
GSPLAT_MODEL_PATH=/models/gsplat_pretrained.pt

# Maximum Gaussians per scene (trade-off: more = better quality, slower rendering)
GSPLAT_MAX_GAUSSIANS=1000000

# Spherical Harmonic degree (0=mobile/fast, 1=balanced, 2/3=desktop/quality)
GSPLAT_SH_DEGREE=1

# ──── IoT SENSORS (Environmental Data) – PHASE 2 CONTEXT ──────────────────────────
# Integrates HVAC, temperature, humidity, air quality sensors
# Enables contextual voice responses ("The temperature in the master bedroom is 22°C")

IOT_ENABLE=true

# MQTT broker for sensor data streaming
IOT_MQTT_BROKER=mqtt://localhost:1883

# Polling interval for sensor updates (seconds)
IOT_SENSOR_POLL_INTERVAL_SEC=30

# ──── XR/AR (WebXR, Hand Tracking) – PHASE 3 (NOT YET IMPLEMENTED) ─────────────────
# Planned for Q3 2026: Meta Quest, Apple Vision Pro, HoloLens support

XR_ENABLE=false
XR_WEBXR_SUPPORTED=false

# ═════════════════════════════════════════════════════════════════════════════════════
# PHASE 2 QUICK START GUIDE
# ═════════════════════════════════════════════════════════════════════════════════════
#
# To FULLY ENABLE Phase 2, you need:
#
# 1. VOICE ASSISTANT (1 week effort):
#    ✓ Set OPENAI_API_KEY (for Whisper STT + TTS + optional GPT LLM)
#    ✓ Or set ANTHROPIC_API_KEY + ELEVENLABS_API_KEY
#    Result: Users can ask property questions verbally
#
# 2. COMPUTER VISION (2-3 weeks effort):
#    ✓ Download YOLOv12 and RT-DETR model weights
#    ✓ Set YOLOV12_MODEL_PATH, RTDETR_MODEL_PATH
#    ✓ Ensure INSPECTION_DEVICE=cuda (needs GPU for real-time inference)
#    Result: Click "Run AI Inspection" → get structural defect detection
#
# 3. GSplat 3D VIEWER (3-4 weeks effort):
#    ✓ Capture property video (30+ min, 70%+ frame overlap)
#    ✓ Run COLMAP Structure-from-Motion to get point cloud
#    ✓ Train Gaussians using gsplat_pipeline.py
#    ✓ Upload .splat file to backend
#    Result: 3D property walkthrough in browser
#
# 4. IoT SENSORS (1-2 weeks effort):
#    ✓ Deploy MQTT broker
#    ✓ Connect HVAC/environmental sensors to MQTT
#    ✓ Voice agent queries IoT data ("How warm is the bedroom?")
#    Result: Contextual voice responses with real sensor data
#
# 5. XR/AR (4-8 weeks effort — Q3 2026):
#    ✓ Choose platform: Meta Quest, Apple Vision Pro, or WebXR
#    ✓ Implement hand gesture recognition
#    ✓ Port GSplat viewer to XR viewport
#    ✓ Integrate spatial audio
#    Result: Immersive XR property walkthrough
#
# ═════════════════════════════════════════════════════════════════════════════════════
# SECURITY BEST PRACTICES
# ═════════════════════════════════════════════════════════════════════════════════════
#
# ⚠️  NEVER commit your .env file to version control
# ⚠️  Use AWS Secrets Manager, HashiCorp Vault, or similar for production
# ⚠️  Rotate API keys every 90 days
# ⚠️  Use separate API keys for development, staging, and production
# ⚠️  Restrict API key permissions to minimum required scope
# ⚠️  Monitor API usage for suspicious activity
#
# ═════════════════════════════════════════════════════════════════════════════════════
